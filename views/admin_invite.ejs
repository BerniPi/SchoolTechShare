<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Benutzer einladen - SchoolTechShare</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-gray-50 text-gray-800 min-h-screen">
    <%- include('partials/navbar', { activePage: 'users' }) %>

    <main class="max-w-3xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
        <div class="bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden">
            <div class="bg-indigo-600 py-6 px-8">
                <h1 class="text-2xl font-bold text-white">Neuen Benutzer einladen</h1>
                <p class="text-indigo-100 mt-2">Laden Sie Lehrer oder Mitarbeiter in das System ein und weisen Sie ihnen eine Schule zu.</p>
            </div>
            
            <div class="p-8">
                <% if (error) { %>
                    <div class="mb-6 bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-md text-sm">
                        <%= error %>
                    </div>
                <% } %>

                <% if (successLink) { %>
                    <div class="mb-6 bg-green-50 border border-green-200 p-6 rounded-md">
                        <h3 class="text-green-800 font-bold mb-2">Einladung erfolgreich erstellt!</h3>
                        <p class="text-green-700 text-sm mb-4">Senden Sie den folgenden Link an den Benutzer. Damit kann er sein Passwort setzen und die Registrierung abschließen:</p>
                        <div class="flex items-center gap-2">
                            <input type="text" readonly value="<%= successLink %>" class="block w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm text-gray-600 font-mono shadow-sm" onclick="this.select();">
                        </div>
                    </div>
                <% } %>

                <form action="/admin/invite" method="POST" class="space-y-6">
                    <div>
                        <label for="email" class="block text-sm font-semibold text-gray-700">E-Mail-Adresse des Benutzers</label>
                        <input type="email" name="email" id="email" required placeholder="lehrer@schule.de" class="mt-2 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm transition-shadow">
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Schulen zuweisen (mehrere möglich)</label>
                        <div class="mt-2 space-y-2 border border-gray-300 rounded-md p-4 bg-white max-h-48 overflow-y-auto">
                            <% if (schools && schools.length > 0) { %>
                                <% schools.forEach(function(school) { %>
                                    <label class="flex items-center">
                                        <input type="checkbox" name="school_ids[]" value="<%= school.school_id %>" class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded">
                                        <span class="ml-2 text-sm text-gray-700"><%= school.name %> (<%= school.school_code %>)</span>
                                    </label>
                                <% }) %>
                            <% } else { %>
                                <p class="text-sm text-gray-500">Keine Schulen gefunden.</p>
                            <% } %>
                        </div>
                    </div>

                    <div class="pt-4 flex justify-end gap-3">
                        <button type="submit" class="inline-flex justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition-colors">
                            Einladungslink generieren
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </main>
</body>
</html>
