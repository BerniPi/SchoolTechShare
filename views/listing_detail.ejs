<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= listing.title %> - SchoolTechShare</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-gray-50 text-gray-800 min-h-screen">
    <%- include('partials/navbar', { activePage: 'listings' }) %>

    <main class="max-w-4xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
        <div class="mb-6">
            <a href="/offers" class="text-indigo-600 hover:text-indigo-800 text-sm font-medium flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                Zurück zur Übersicht
            </a>
        </div>

        <div class="bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden">
            <!-- Header Section -->
            <div class="p-8 border-b border-gray-100">
                <div class="flex justify-between items-start">
                    <div>
                        <div class="flex items-center gap-3 mb-2">
                            <span class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider <%= listing.type === 'offer' ? 'bg-green-100 text-green-800' : 'bg-blue-100 text-blue-800' %>">
                                <%= listing.type === 'offer' ? 'Angebot' : 'Suche' %>
                            </span>
                            <span class="text-sm text-gray-500"><%= new Date(listing.created_at).toLocaleDateString('de-DE') %></span>
                        </div>
                        <h1 class="text-3xl font-bold text-gray-900">
                            <%= (listing.quantity && listing.quantity > 1) ? listing.quantity + 'x ' : '' %><%= listing.title %>
                        </h1>
                        <div class="mt-2 flex flex-wrap gap-2">
                            <% if (listing.type === 'offer' && listing.condition) { %>
                                <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-bold bg-indigo-50 text-indigo-700 border border-indigo-100 uppercase tracking-wide">
                                    Zustand: <%= listing.condition %>
                                </span>
                            <% } %>
                            <% if (listing.manufacturer) { %>
                                <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-bold bg-gray-50 text-gray-700 border border-gray-100 uppercase tracking-wide">
                                    Hersteller: <%= listing.manufacturer %>
                                </span>
                            <% } %>
                        </div>
                    </div>
                    <div class="flex flex-col items-end gap-4">
                        <% 
                            let statusClass = 'bg-gray-100 text-gray-700 border border-gray-200';
                            let statusText = 'Erledigt';
                            if (listing.status === 'active') {
                                statusClass = 'bg-green-50 text-green-700 border border-green-200';
                                statusText = 'Aktiv';
                            } else if (listing.status === 'reserved') {
                                statusClass = 'bg-yellow-50 text-yellow-700 border border-yellow-200';
                                statusText = 'Reserviert';
                            }
                        %>
                        <span class="px-3 py-1 rounded-full text-sm font-medium <%= statusClass %>">
                            Status: <%= statusText %>
                        </span>

                        <% if (user && (user.user_id === listing.user_id || user.role === 'admin')) { %>
                            <div class="flex flex-wrap justify-end gap-2 max-w-md">
                                <div class="flex gap-2">
                                    <% if (listing.status === 'active') { %>
                                        <% if (listing.type === 'offer') { %>
                                            <form action="/listing/<%= listing.listing_id %>/status" method="POST" class="inline">
                                                <input type="hidden" name="status" value="reserved">
                                                <button type="submit" class="inline-flex items-center px-3 py-1.5 border border-transparent shadow-sm text-xs font-bold rounded-md text-white bg-yellow-600 hover:bg-yellow-700 transition-colors uppercase tracking-wider">
                                                    Reservieren
                                                </button>
                                            </form>
                                        <% } %>
                                        <form action="/listing/<%= listing.listing_id %>/status" method="POST" class="inline">
                                            <input type="hidden" name="status" value="resolved">
                                            <button type="submit" class="inline-flex items-center px-3 py-1.5 border border-transparent shadow-sm text-xs font-bold rounded-md text-white bg-green-600 hover:bg-green-700 transition-colors uppercase tracking-wider">
                                                Erledigen
                                            </button>
                                        </form>
                                    <% } else if (listing.status === 'reserved') { %>
                                        <form action="/listing/<%= listing.listing_id %>/status" method="POST" class="inline">
                                            <input type="hidden" name="status" value="active">
                                            <button type="submit" class="inline-flex items-center px-3 py-1.5 border border-gray-300 shadow-sm text-xs font-bold rounded-md text-gray-700 bg-white hover:bg-gray-50 transition-colors uppercase tracking-wider">
                                                Freigeben
                                            </button>
                                        </form>
                                        <form action="/listing/<%= listing.listing_id %>/status" method="POST" class="inline">
                                            <input type="hidden" name="status" value="resolved">
                                            <button type="submit" class="inline-flex items-center px-3 py-1.5 border border-transparent shadow-sm text-xs font-bold rounded-md text-white bg-green-600 hover:bg-green-700 transition-colors uppercase tracking-wider">
                                                Erledigen
                                            </button>
                                        </form>
                                    <% } else if (listing.status === 'resolved') { %>
                                        <form action="/listing/<%= listing.listing_id %>/status" method="POST" class="inline">
                                            <input type="hidden" name="status" value="active">
                                            <button type="submit" class="inline-flex items-center px-3 py-1.5 border border-gray-300 shadow-sm text-xs font-bold rounded-md text-gray-700 bg-white hover:bg-gray-50 transition-colors uppercase tracking-wider">
                                                Reaktivieren
                                            </button>
                                        </form>
                                    <% } %>
                                </div>

                                <div class="hidden sm:block h-8 w-px bg-gray-200 mx-1"></div>

                                <div class="flex gap-2">
                                    <a href="/listing/<%= listing.listing_id %>/edit" class="inline-flex items-center px-3 py-1.5 border border-gray-300 shadow-sm text-xs font-bold rounded-md text-gray-700 bg-white hover:bg-gray-50 transition-colors uppercase tracking-wider">
                                        Edit
                                    </a>
                                    <form action="/listing/<%= listing.listing_id %>/delete" method="POST" class="inline" onsubmit="return confirm('Möchten Sie dieses Inserat wirklich löschen?');">
                                        <button type="submit" class="inline-flex items-center px-3 py-1.5 border border-transparent shadow-sm text-xs font-bold rounded-md text-white bg-red-600 hover:bg-red-700 transition-colors uppercase tracking-wider">
                                            Löschen
                                        </button>
                                    </form>
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>
                
                <% if (listing.status === 'reserved' && listing.reserved_at) { %>
                    <div class="mt-4 px-3 py-2 bg-yellow-50 border border-yellow-100 rounded-md text-xs text-yellow-800">
                        <strong>Reserviert am:</strong> <%= new Date(listing.reserved_at).toLocaleString('de-DE') %>
                    </div>
                <% } else if (listing.status === 'resolved' && listing.resolved_at) { %>
                    <div class="mt-4 px-3 py-2 bg-green-50 border border-green-100 rounded-md text-xs text-green-800">
                        <strong>Erledigt am:</strong> <%= new Date(listing.resolved_at).toLocaleString('de-DE') %>
                    </div>
                <% } %>
            </div>

            <!-- Content Section -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 p-8">
                <!-- Left: Info & Description -->
                <div class="md:col-span-2 space-y-6">
                    <div>
                        <h3 class="text-lg font-semibold text-gray-900 mb-2">Beschreibung</h3>
                        <p class="text-gray-600 whitespace-pre-wrap leading-relaxed"><%= listing.description %></p>
                    </div>

                    <% if (tags && tags.length > 0) { %>
                        <div>
                            <h3 class="text-sm font-semibold text-gray-900 mb-2">Tags</h3>
                            <div class="flex flex-wrap gap-2">
                                <% tags.forEach(function(tag) { %>
                                    <span class="px-2 py-1 bg-gray-100 text-gray-600 rounded text-xs font-medium border border-gray-200"><%= tag %></span>
                                <% }) %>
                            </div>
                        </div>
                    <% } %>
                </div>

                <!-- Right: Contact & Details -->
                <div class="space-y-6">
                    <div class="bg-gray-50 rounded-lg p-5 border border-gray-100">
                        <h3 class="text-sm font-semibold text-gray-900 mb-4 uppercase tracking-wide">Kontaktdaten</h3>
                        <div class="space-y-3">
                            <div>
                                <p class="text-xs text-gray-500">Veröffentlicht von</p>
                                <p class="font-medium text-gray-900"><%= listing.user_name || listing.user_email %></p>
                            </div>
                            <div>
                                <p class="text-xs text-gray-500">Schule</p>
                                <p class="font-medium text-gray-900"><%= listing.school_name %></p>
                            </div>
                            <div class="pt-3">
                                <a href="mailto:<%= listing.user_email %>?subject=SchoolTechShare: <%= listing.title %>" class="w-full inline-flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors">
                                    Benutzer kontaktieren
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Photos Section -->
            <% if (images && images.length > 0) { %>
                <div class="p-8 bg-gray-50 border-t border-gray-100">
                    <h3 class="text-lg font-semibold text-gray-900 mb-4">Fotos</h3>
                    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                        <% images.forEach(function(img) { %>
                            <div onclick="openModal('<%= img.file_path %>')" class="cursor-pointer block aspect-w-4 aspect-h-3 rounded-lg overflow-hidden border border-gray-200 hover:shadow-md transition-shadow">
                                <img src="<%= img.file_path %>" alt="Listing photo" class="w-full h-full object-cover">
                            </div>
                        <% }) %>
                    </div>
                </div>
            <% } %>

        </div>
    </main>

    <!-- Image Modal -->
    <div id="imageModal" class="fixed inset-0 z-50 hidden bg-black/90 flex items-center justify-center p-4 backdrop-blur-sm transition-opacity" onclick="closeModal()">
        <button class="absolute top-6 right-6 text-white hover:text-gray-300 focus:outline-none transition-colors" onclick="closeModal()">
            <svg class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>
        <img id="modalImage" src="" class="max-h-[90vh] max-w-[90vw] object-contain rounded-lg shadow-2xl" onclick="event.stopPropagation()">
    </div>

    <script>
        function openModal(src) {
            document.getElementById('modalImage').src = src;
            document.getElementById('imageModal').classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }

        function closeModal() {
            document.getElementById('imageModal').classList.add('hidden');
            setTimeout(() => { document.getElementById('modalImage').src = ''; }, 300); // clear after hide
            document.body.style.overflow = '';
        }

        document.addEventListener('keydown', function(event) {
            if (event.key === "Escape") {
                closeModal();
            }
        });
    </script>
</body>
</html>
