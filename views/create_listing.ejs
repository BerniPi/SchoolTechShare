<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inserat erstellen - SchoolTechShare</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-gray-50 text-gray-800 min-h-screen">
    <%- include('partials/navbar', { activePage: 'listings' }) %>

    <main class="max-w-3xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
        <div class="bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden">
            <div class="bg-indigo-600 py-6 px-8">
                <h1 class="text-2xl font-bold text-white">Neues Inserat erstellen</h1>
                <p class="text-indigo-100 mt-2">Bieten Sie Hardware an oder fragen Sie benötigte Technik für Ihre Schule an.</p>
            </div>
            
            <form action="/listing/new" method="POST" enctype="multipart/form-data" class="p-8 space-y-6">
                <!-- Type Selection -->
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Inseratstyp</label>
                    <div class="flex gap-4">
                        <label class="flex items-center p-4 border border-gray-200 rounded-lg cursor-pointer hover:bg-gray-50 flex-1 transition-colors">
                            <input type="radio" name="type" value="offer" class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300" <%= (typeof type === 'undefined' || type !== 'request') ? 'checked' : '' %> onchange="toggleCondition(this.value)">
                            <span class="ml-3 font-medium text-gray-900">Hardware anbieten</span>
                        </label>
                        <label class="flex items-center p-4 border border-gray-200 rounded-lg cursor-pointer hover:bg-gray-50 flex-1 transition-colors">
                            <input type="radio" name="type" value="request" class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300" <%= (typeof type !== 'undefined' && type === 'request') ? 'checked' : '' %> onchange="toggleCondition(this.value)">
                            <span class="ml-3 font-medium text-gray-900">Hardware anfragen</span>
                        </label>
                    </div>
                </div>

                <!-- Condition (Only for Offers) -->
                <div id="condition-container" class="<%= (typeof type !== 'undefined' && type === 'request') ? 'hidden' : '' %>">
                    <label for="condition" class="block text-sm font-semibold text-gray-700">Zustand der Hardware</label>
                    <select name="condition" id="condition" class="mt-2 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm transition-shadow">
                        <option value="Gebraucht" selected>Gebraucht</option>
                        <option value="Neu">Neu</option>
                        <option value="Neuwertig">Neuwertig</option>
                        <option value="Defekt">Defekt / Ersatzteilspender</option>
                    </select>
                </div>

                <script>
                    function toggleCondition(type) {
                        const container = document.getElementById('condition-container');
                        if (type === 'offer') {
                            container.classList.remove('hidden');
                        } else {
                            container.classList.add('hidden');
                        }
                    }
                </script>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Quantity -->
                    <div>
                        <label for="quantity" class="block text-sm font-semibold text-gray-700">Anzahl / Menge</label>
                        <input type="number" name="quantity" id="quantity" min="1" value="1" required class="mt-2 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm transition-shadow">
                    </div>

                    <!-- Title -->
                    <div>
                        <label for="title" class="block text-sm font-semibold text-gray-700">Titel</label>
                        <input type="text" name="title" id="title" required placeholder="z.B. Dell Optiplex Monitore" class="mt-2 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm transition-shadow">
                    </div>

                    <!-- Manufacturer -->
                    <div>
                        <label for="manufacturer" class="block text-sm font-semibold text-gray-700">Hersteller (optional)</label>
                        <input type="text" name="manufacturer" id="manufacturer" placeholder="z.B. Dell, HP, Apple" class="mt-2 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm transition-shadow">
                    </div>
                </div>

                <!-- Description -->
                <div>
                    <label for="description" class="block text-sm font-semibold text-gray-700">Beschreibung</label>
                    <textarea name="description" id="description" rows="4" placeholder="Beschreiben Sie den Zustand, die Spezifikationen oder warum Sie diese Hardware benötigen..." class="mt-2 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm transition-shadow"></textarea>
                </div>

                <!-- Tags Selection -->
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-3">Hardware-Kategorien (Tags)</label>
                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 max-h-64 overflow-y-auto p-4 border border-gray-200 rounded-lg bg-gray-50">
                        <% allTags.forEach(function(tag) { %>
                            <label class="flex items-center space-x-3 p-2 rounded-md hover:bg-white transition-colors cursor-pointer border border-transparent hover:border-gray-100">
                                <input type="checkbox" name="tags" value="<%= tag.name %>" class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded">
                                <span class="text-sm text-gray-700"><%= tag.name %></span>
                            </label>
                        <% }) %>
                    </div>
                    <p class="mt-2 text-xs text-gray-500">Wählen Sie passende Merkmale für Ihre Hardware aus.</p>
                </div>

                <!-- School Selection -->
                <div>
                    <label for="school_id" class="block text-sm font-semibold text-gray-700">Schule des Inserats</label>
                    <% if (schools && schools.length > 1) { %>
                        <select name="school_id" id="school_id" required class="mt-2 block w-full rounded-md border border-gray-300 bg-white px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm transition-shadow">
                            <% schools.forEach(function(school) { %>
                                <option value="<%= school.school_id %>"><%= school.name %></option>
                            <% }) %>
                        </select>
                    <% } else if (schools && schools.length === 1) { %>
                        <input type="hidden" name="school_id" value="<%= schools[0].school_id %>">
                        <input type="text" disabled value="<%= schools[0].name %>" class="mt-2 block w-full rounded-md border border-gray-300 bg-gray-50 px-3 py-2 shadow-sm text-gray-500 sm:text-sm">
                    <% } else { %>
                        <input type="hidden" name="school_id" value="">
                        <p class="text-sm text-red-600 mt-2">Sie sind keiner Schule zugewiesen. Bitte kontaktieren Sie einen Administrator.</p>
                    <% } %>
                </div>

                <!-- Photos -->
                <div>
                    <label for="photos" class="block text-sm font-semibold text-gray-700">Fotos hochladen (Max. 5)</label>
                    <div class="mt-2 flex justify-center rounded-md border-2 border-dashed border-gray-300 px-6 pt-5 pb-6 hover:bg-gray-50 transition-colors">
                        <div class="space-y-1 text-center">
                            <svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48" aria-hidden="true">
                                <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            <div class="flex text-sm text-gray-600 justify-center">
                                <label for="photos" class="relative cursor-pointer rounded-md bg-transparent font-medium text-indigo-600 focus-within:outline-none focus-within:ring-2 focus-within:ring-indigo-500 focus-within:ring-offset-2 hover:text-indigo-500">
                                    <span>Dateien hochladen</span>
                                    <input id="photos" name="photos" type="file" multiple accept="image/*" class="sr-only" onchange="updateFileList(this)">
                                </label>
                                <p class="pl-1">oder per Drag & Drop</p>
                            </div>
                            <p class="text-xs text-gray-500">PNG, JPG, GIF bis zu 5MB pro Datei</p>
                        </div>
                    </div>
                    <!-- Display selected files -->
                    <ul id="file-list" class="mt-3 text-sm text-gray-600 space-y-1 pl-2 list-disc hidden"></ul>
                </div>

                <!-- Submit -->
                <div class="pt-4 flex justify-end gap-3">
                    <a href="/offers" class="inline-flex items-center rounded-md border border-gray-300 bg-white py-2 px-4 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition-colors">
                        Abbrechen
                    </a>
                    <button type="submit" class="inline-flex justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition-colors">
                        Inserat veröffentlichen
                    </button>
                </div>
            </form>
        </div>
    </main>

    <script>
        function updateFileList(input) {
            const list = document.getElementById('file-list');
            list.innerHTML = '';
            
            if (input.files.length > 5) {
                alert('Sie können maximal 5 Fotos hochladen.');
                input.value = ''; // Clear selection
                list.classList.add('hidden');
                return;
            }

            if (input.files.length > 0) {
                list.classList.remove('hidden');
                Array.from(input.files).forEach(file => {
                    const li = document.createElement('li');
                    li.textContent = file.name;
                    list.appendChild(li);
                });
            } else {
                list.classList.add('hidden');
            }
        }
    </script>
</body>
</html>
