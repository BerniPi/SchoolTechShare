<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registrierung abschließen - SchoolTechShare</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-gray-50 text-gray-800 min-h-screen flex flex-col justify-center py-12 sm:px-6 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-md">
        <h2 class="mt-6 text-center text-3xl font-bold tracking-tight text-indigo-600">SchoolTechShare</h2>
        <p class="mt-2 text-center text-sm text-gray-600">
            Schließen Sie Ihre Registrierung für <strong><%= email %></strong> ab.
        </p>
    </div>

    <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
        <div class="bg-white py-8 px-4 shadow sm:rounded-lg sm:px-10 border border-gray-100">
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="mb-4 bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-md text-sm">
                    <%= error %>
                </div>
            <% } %>

            <form class="space-y-6" action="/invite/<%= token %>" method="POST">
                <input type="hidden" name="email" value="<%= email %>">
                
                <div>
                    <label for="name" class="block text-sm font-medium text-gray-700">Vollständiger Name</label>
                    <div class="mt-1">
                        <input id="name" name="name" type="text" required placeholder="Max Mustermann"
                            class="block w-full appearance-none rounded-md border border-gray-300 px-3 py-2 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-indigo-500 sm:text-sm transition-shadow">
                    </div>
                </div>

                <div>
                    <label for="phone_number" class="block text-sm font-medium text-gray-700">Telefonnummer (optional)</label>
                    <div class="mt-1">
                        <input id="phone_number" name="phone_number" type="text" placeholder="+49 123 4567890"
                            class="block w-full appearance-none rounded-md border border-gray-300 px-3 py-2 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-indigo-500 sm:text-sm transition-shadow">
                    </div>
                </div>

                <div>
                    <label for="password" class="block text-sm font-medium text-gray-700">Passwort festlegen</label>
                    <div class="mt-1">
                        <input id="password" name="password" type="password" required minlength="6"
                            class="block w-full appearance-none rounded-md border border-gray-300 px-3 py-2 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-indigo-500 sm:text-sm transition-shadow">
                    </div>
                </div>

                <div>
                    <button type="submit"
                        class="flex w-full justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition-colors">
                        Registrierung abschließen
                    </button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>
