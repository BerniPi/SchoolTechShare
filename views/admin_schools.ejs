<!DOCTYPE html>
<html lang="de">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Schulen verwalten - SchoolTechShare</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>

<body class="bg-gray-50 text-gray-800 min-h-screen">
    <%- include('partials/navbar', { activePage: 'schools' }) %>

    <main class="max-w-5xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- Add School Form -->
            <div class="md:col-span-1">
                <div class="bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden">
                    <div class="bg-indigo-600 py-4 px-6">
                        <h2 class="text-lg font-bold text-white">Neue Schule hinzufügen</h2>
                    </div>

                    <div class="p-6">
                        <% if (error) { %>
                            <div class="mb-4 bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-md text-sm">
                                <%= error %>
                            </div>
                            <% } %>

                                <form action="/admin/schools" method="POST" class="space-y-4">
                                    <div>
                                        <label for="school_code"
                                            class="block text-sm font-semibold text-gray-700">Schulkennzahl</label>
                                        <input type="text" name="school_code" id="school_code" required
                                            placeholder="z.B. 802026"
                                            class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm">
                                    </div>

                                    <div>
                                        <label for="name" class="block text-sm font-semibold text-gray-700">Name der
                                            Schule</label>
                                        <input type="text" name="name" id="name" required
                                            placeholder="z.B. Goethe-Gymnasium"
                                            class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm">
                                    </div>

                                    <div>
                                        <label for="address"
                                            class="block text-sm font-semibold text-gray-700">Adresse</label>
                                        <input type="text" name="address" id="address" placeholder="Musterstraße 1"
                                            class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm">
                                    </div>

                                    <div>
                                        <label for="city"
                                            class="block text-sm font-semibold text-gray-700">Stadt</label>
                                        <input type="text" name="city" id="city" placeholder="Bregenz"
                                            class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm">
                                    </div>

                                    <div class="pt-2">
                                        <button type="submit"
                                            class="w-full flex justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition-colors">
                                            Schule speichern
                                        </button>
                                    </div>
                                </form>
                    </div>
                </div>
            </div>

            <!-- Schools List -->
            <div class="md:col-span-2">
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                    <div class="px-6 py-4 border-b border-gray-200 bg-gray-50 flex justify-between items-center">
                        <h2 class="text-lg font-bold text-gray-900">Alle registrierten Schulen</h2>
                        <span
                            class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">
                            <%= schools.length %> Schulen
                        </span>
                    </div>

                    <div class="divide-y divide-gray-200">
                        <% if (schools && schools.length> 0) { %>
                            <% schools.forEach(function(school) { %>
                                <div class="p-6 hover:bg-gray-50 transition-colors">
                                    <div class="flex justify-between items-start">
                                        <div>
                                            <h3 class="text-lg font-bold text-gray-900">
                                                <%= school.name %>
                                            </h3>
                                            <p class="text-sm text-gray-500 mt-1">
                                                <%= school.address ? school.address + ', ' : '' %>
                                                    <%= school.city || '' %>
                                            </p>
                                        </div>
                                        <div class="flex items-center gap-3">
                                            <span
                                                class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium bg-gray-100 text-gray-800 border border-gray-200 font-mono">
                                                <%= school.school_code %>
                                            </span>
                                            <a href="/admin/schools/<%= school.school_id %>/edit" class="text-indigo-600 hover:text-indigo-900 text-sm font-medium">Bearbeiten</a>
                                            <form action="/admin/schools/<%= school.school_id %>/delete" method="POST" class="inline" onsubmit="return confirm('Möchten Sie diese Schule wirklich löschen?');">
                                                <button type="submit" class="text-red-600 hover:text-red-900 text-sm font-medium">Löschen</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                                <% }) %>
                                    <% } else { %>
                                        <div class="p-12 text-center text-gray-500">
                                            Keine Schulen gefunden.
                                        </div>
                                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </main>
</body>

</html>