<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Schule bearbeiten - SchoolTechShare</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-gray-50 text-gray-800 min-h-screen">
    <%- include('partials/navbar', { activePage: 'schools' }) %>

    <main class="max-w-2xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
        <div class="bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden">
            <div class="bg-indigo-600 py-6 px-8">
                <h1 class="text-2xl font-bold text-white">Schule bearbeiten</h1>
            </div>
            
            <div class="p-8">
                <% if (error) { %>
                    <div class="mb-6 bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-md text-sm">
                        <%= error %>
                    </div>
                <% } %>

                <form action="/admin/schools/<%= school.school_id %>/edit" method="POST" class="space-y-6">
                    <div>
                        <label for="school_code" class="block text-sm font-semibold text-gray-700">Schulkennzahl (Eindeutig)</label>
                        <input type="text" name="school_code" id="school_code" required value="<%= school.school_code %>" class="mt-2 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm transition-shadow">
                    </div>

                    <div>
                        <label for="name" class="block text-sm font-semibold text-gray-700">Name der Schule</label>
                        <input type="text" name="name" id="name" required value="<%= school.name %>" class="mt-2 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm transition-shadow">
                    </div>

                    <div>
                        <label for="address" class="block text-sm font-semibold text-gray-700">Adresse</label>
                        <input type="text" name="address" id="address" value="<%= school.address || '' %>" class="mt-2 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm transition-shadow">
                    </div>

                    <div>
                        <label for="city" class="block text-sm font-semibold text-gray-700">Stadt</label>
                        <input type="text" name="city" id="city" value="<%= school.city || '' %>" class="mt-2 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 sm:text-sm transition-shadow">
                    </div>

                    <div class="pt-4 flex justify-end gap-3">
                        <a href="/admin/schools" class="inline-flex items-center rounded-md border border-gray-300 bg-white py-2 px-4 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition-colors">
                            Abbrechen
                        </a>
                        <button type="submit" class="inline-flex justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition-colors">
                            Änderungen speichern
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </main>
</body>
</html>
